# Unreal Engine generated files
/Binaries/
/DerivedDataCache/
/Intermediate/
/Saved/

# Large optional Fab imports. Keep wired in code/docs, but do not commit full packs.
/Content/MedievalDungeon/
/Content/ParagonMinions/

# Unreal generated project and workspace files
/.vs/
/.vscode/
/.idea/
/*.sln
/*.suo
/*.opensdf
/*.sdf
/*.VC.db
/*.VC.VC.opendb
/*.xcodeproj/
/*.xcworkspace/
/*.xcuserdata/

# Unreal build artifacts
/Build/*/FileOpenOrder/
/Build/*/FileOpenOrder/*
*.target
*.modules
*.version
*.pdb
*.ilk
*.obj
*.pch
*.idb
*.lib
*.dll
*.exe
*.app
*.dSYM/

# Unreal Automation Tool and packaged output
/AutomationTool/
/LocalBuilds/
/Releases/
/StagedBuilds/
/Packaged/

# Logs and crash dumps
*.log
*.tmp
*.temp
*.dmp
*.mdmp

# Windows local files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS local files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100/
.Trashes/
.fseventsd/

# Rider and JetBrains generated Unreal folders
/.Rider/
/.idea/
*.sln.DotSettings.user

# Visual Studio Code local settings, keep shared recommendations if added later
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json

# Python and tooling caches sometimes created by helpers
__pycache__/
*.py[cod]
.pytest_cache/

# Keep project-critical source and configuration tracked
!/Config/
!/Source/
!/*.uproject
!/*.bat
!/README.md
!/AGENTS.md
